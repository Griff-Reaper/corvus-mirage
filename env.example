# ─────────────────────────────────────────
# CORVUS MIRAGE — Environment Configuration
# Copy this file to .env and fill in values
# Never commit .env to version control
# ─────────────────────────────────────────

# ── Anthropic ──────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Twilio (ARIA Voice Layer) ──────────────
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# ── Deepgram (Real-time STT) ───────────────
DEEPGRAM_API_KEY=your_deepgram_api_key

# ── ARIA ───────────────────────────────────
ARIA_HOST=0.0.0.0
ARIA_PORT=8000
ARIA_SECRET_KEY=generate_a_strong_secret_key
ARIA_LOG_LEVEL=INFO

# ── Gateway ────────────────────────────────
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8001
GATEWAY_SECRET_KEY=generate_a_strong_secret_key
GATEWAY_LOG_LEVEL=INFO

# ── Red Team Simulator ─────────────────────
RED_TEAM_HOST=0.0.0.0
RED_TEAM_PORT=8002
RED_TEAM_TARGET_ARIA=http://localhost:8000
RED_TEAM_TARGET_GATEWAY=http://localhost:8001

# ── Dashboard ──────────────────────────────
DASHBOARD_PORT=3000
NEXT_PUBLIC_ARIA_API=http://localhost:8000
NEXT_PUBLIC_GATEWAY_API=http://localhost:8001
NEXT_PUBLIC_RED_TEAM_API=http://localhost:8002

# ── Shared ─────────────────────────────────
THREAT_INTEL_DB_PATH=./shared/data/threat_intel.db
ALERT_WEBHOOK_URL=your_slack_or_webhook_url
ENVIRONMENT=development
